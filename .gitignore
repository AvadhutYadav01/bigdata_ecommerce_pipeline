.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the values are
#   specific to the developer's system. But for a builds/deployments/apps, they might be
#   useful.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a windows machine, Pipfile.lock might not be
#   compatible with other OSs.
# Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock contains the exact dependency versions.
#   It is typically recommended to commit it, but can be ignored if desired.
# poetry.lock

# pdm
#   Similar to Pipenv and Poetry, pdm.lock contains the exact dependency versions.
# pdm.lock
#   pdm local configuration
.pdm-python.path
.pdm-build/

# PEP 582; used by e.g. github.com/lincolnloop/layman and github.com/pdm-project/pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

